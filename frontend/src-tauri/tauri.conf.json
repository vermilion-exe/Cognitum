{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cognitum-frontend",
  "version": "0.1.0",
  "identifier": "com.cognitum.frontend",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cognitum-frontend",
        "width": 1400,
        "height": 1000,
        "minWidth": 1000,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "additionalBrowserArgs": "--remote-debugging-port=9222"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/manual.md", "resources/*"]
  }
}
